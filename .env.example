# Docker Compose environment variables
# Copy this to .env and fill in with your actual values

# Database
DB_USER=harsh
DB_PASSWORD=your_secure_password_here
DB_NAME=job_agent

# FastAPI backend
DATABASE_URL=postgresql+asyncpg://harsh:your_secure_password_here@db:5432/job_agent
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=optional_api_key

# Email Configuration (Resend with default pre-verified subdomain)
# No DNS setup required - onboarding@resend.dev is ready to use immediately
EMAIL_SENDER=onboarding@resend.dev
EMAIL_PASSWORD=your_resend_api_key_here
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=587
EMAIL_RECIPIENT=harshsaindane1711@gmail.com

# LLM & Embeddings
MISTRAL_API_KEY=your_mistral_api_key_here
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=agentic-job-finder

# Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
AUTH_SECRET=your_nextauth_secret_here
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application
DEVELOPMENT_MODE=true
