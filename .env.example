# Docker Compose environment variables
# Copy this to .env and fill in with your actual values

# Database
DB_USER=your_db_user_here
DB_PASSWORD=your_secure_password_here
DB_NAME=your_db_name_here

# FastAPI backend
DATABASE_URL=postgresql+asyncpg://your_db_user_here:your_secure_password_here@db:5432/your_db_name_here
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=optional_api_key


EMAIL_SENDER=sender@gmail.com
EMAIL_PASSWORD=your_google_app_password_here
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_RECIPIENT=recipient@gmail.com

# LLM & Embeddings
MISTRAL_API_KEY=your_mistral_api_key_here
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentic-job-finder

# Authentication (NextAuth)
JWT_SECRET_KEY=your_jwt_secret_key_here
AUTH_SECRET=your_nextauth_secret_here
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000


# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001

# Application
DEVELOPMENT_MODE=true
